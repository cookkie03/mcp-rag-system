# ============================================================
# RAG System - Variabili d'Ambiente (opzionali)
# Copia questo file in .env e modifica i valori
# ============================================================

# LLM API Key (OpenAI-compatible)
# Per Ollama locale: non serve, lascia "ollama"
# Per LM Studio locale: non serve, lascia "lm-studio"
# Per OpenAI: inserisci la tua API key (sk-...)
# Per Together/Groq/ecc: inserisci la relativa API key
# Sovrascrive llm.api_key in config.yaml se presente
LLM_API_KEY=ollama

# LLM Base URL (OpenAI-compatible)
# Per Ollama: http://localhost:11434/v1
# Per LM Studio: http://localhost:1234/v1
# Per OpenAI: https://api.openai.com/v1
# Sovrascrive llm.base_url in config.yaml se presente
LLM_BASE_URL=http://ollama:11434/v1
